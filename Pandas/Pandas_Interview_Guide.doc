            font-size: 1.8em;
        }
        h3 {
            color: #27ae60;
            margin-top: 30px;
            background-color: #f9ebea;
            padding: 10px;
            border-left: 5px solid #e67e22;
            border-radius: 4px;
        }
        ul {
            padding-left: 25px;
        }
        li {
            margin-bottom: 12px;
        }
        table {
            width: 100%;
            border-collapse: collapse;
